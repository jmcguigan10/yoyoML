{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/contracts/diagnostic_bundle.v1.schema.json",
  "title": "Diagnostic Bundle V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at_utc",
    "producer",
    "input",
    "summary",
    "datasets"
  ],
  "properties": {
    "schema_version": {
      "const": "diagnostic_bundle.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "fingerprint"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "fingerprint": {"type": "object"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_count",
        "assumptions_needing_verification",
        "supported_vital_checks",
        "total_vital_checks",
        "readiness_state",
        "confidence_score"
      ],
      "properties": {
        "dataset_count": {"type": "integer", "minimum": 0},
        "assumptions_needing_verification": {"type": "integer", "minimum": 0},
        "supported_vital_checks": {"type": "integer", "minimum": 0},
        "total_vital_checks": {"type": "integer", "minimum": 0},
        "readiness_state": {
          "type": "string",
          "enum": ["ready", "degraded", "blocked"]
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "datasets": {
      "type": "array",
      "items": {"$ref": "#/$defs/dataset"},
      "default": []
    }
  },
  "$defs": {
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported_vital_checks", "total_vital_checks"],
      "properties": {
        "supported_vital_checks": {"type": "integer", "minimum": 0},
        "total_vital_checks": {"type": "integer", "minimum": 0}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "status", "confidence", "summary", "evidence", "warnings"],
      "properties": {
        "key": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "status": {
          "type": "string",
          "enum": ["supported", "needs_input", "unsupported"]
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "summary": {"type": "string"},
        "evidence": {"type": "object"},
        "warnings": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value", "confidence", "status", "source", "evidence", "risk_if_wrong"],
      "properties": {
        "key": {"type": "string", "minLength": 1},
        "value": {},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "status": {
          "type": "string",
          "enum": ["auto_accept", "needs_user_verification", "unresolved"]
        },
        "source": {"type": "string"},
        "evidence": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "risk_if_wrong": {"type": "string"}
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "display_name",
        "detected_type",
        "detection_confidence",
        "input_fingerprint",
        "coverage",
        "dataset_profile",
        "vital_findings",
        "assumptions",
        "warnings",
        "readiness_state",
        "blocking_reasons",
        "required_user_actions",
        "confidence_score"
      ],
      "properties": {
        "dataset_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "detected_type": {"type": "string", "minLength": 1},
        "detection_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "input_fingerprint": {"type": "object"},
        "coverage": {"$ref": "#/$defs/coverage"},
        "dataset_profile": {"type": "object"},
        "vital_findings": {
          "type": "array",
          "items": {"$ref": "#/$defs/finding"},
          "default": []
        },
        "assumptions": {
          "type": "array",
          "items": {"$ref": "#/$defs/assumption"},
          "default": []
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "readiness_state": {
          "type": "string",
          "enum": ["ready", "degraded", "blocked"]
        },
        "blocking_reasons": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "required_user_actions": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "confidence_score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
