{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/contracts/recommendation_bundle.v1.schema.json",
  "title": "Recommendation Bundle V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at_utc",
    "producer",
    "input_diagnostic_hash",
    "summary",
    "datasets"
  ],
  "properties": {
    "schema_version": {
      "const": "recommendation_bundle.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "input_diagnostic_hash": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_count",
        "ready_count",
        "degraded_count",
        "blocked_count",
        "recommendation_count"
      ],
      "properties": {
        "dataset_count": {"type": "integer", "minimum": 0},
        "ready_count": {"type": "integer", "minimum": 0},
        "degraded_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "recommendation_count": {"type": "integer", "minimum": 0}
      }
    },
    "datasets": {
      "type": "array",
      "items": {"$ref": "#/$defs/dataset_recommendation"},
      "default": []
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "rank",
        "family",
        "fit_score",
        "confidence",
        "rationale",
        "collator_intent",
        "hpo_space",
        "risks"
      ],
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "rank": {"type": "integer", "minimum": 1},
        "family": {"type": "string", "minLength": 1},
        "fit_score": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "rationale": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "collator_intent": {"type": "object"},
        "hpo_space": {"type": "object"},
        "risks": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        }
      }
    },
    "dataset_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "display_name",
        "decision_state",
        "required_user_actions",
        "recommended_objective_metric",
        "recommended_validation_strategy",
        "confidence_score",
        "blocking_reasons",
        "candidates"
      ],
      "properties": {
        "dataset_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "decision_state": {
          "type": "string",
          "enum": ["ready", "degraded", "blocked"]
        },
        "required_user_actions": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "recommended_objective_metric": {
          "type": ["string", "null"]
        },
        "recommended_validation_strategy": {
          "type": ["string", "null"]
        },
        "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
        "blocking_reasons": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "candidates": {
          "type": "array",
          "items": {"$ref": "#/$defs/candidate"},
          "default": []
        }
      }
    }
  }
}
