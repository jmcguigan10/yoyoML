{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/contracts/loop_decision_bundle.v1.schema.json",
  "title": "Loop Decision Bundle V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "loop_run_id",
    "round_index",
    "generated_at_utc",
    "producer",
    "decision",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "loop_decision_bundle.v1"
    },
    "run_id": {"type": "string", "minLength": 1},
    "loop_run_id": {"type": "string", "minLength": 1},
    "round_index": {"type": "integer", "minimum": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "reason", "should_emit_probe_requests"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["request_probes", "finalize", "await_operator", "stop"]
        },
        "reason": {"type": "string", "minLength": 1},
        "should_emit_probe_requests": {"type": "boolean"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_count",
        "ready_count",
        "degraded_count",
        "blocked_count",
        "probe_results_seen",
        "mean_confidence_gain"
      ],
      "properties": {
        "dataset_count": {"type": "integer", "minimum": 0},
        "ready_count": {"type": "integer", "minimum": 0},
        "degraded_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "probe_results_seen": {"type": "integer", "minimum": 0},
        "mean_confidence_gain": {"type": "number"}
      }
    }
  }
}
